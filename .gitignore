# Binaries
bin/
pocket-relay-miner
/loadtest

# Tilt
.tilt-tmp/
tilt_config.yaml

# Test & Coverage
coverage.out
coverage.html
*.prof
*.test

# Backend server
tilt/backend-server/backend
tilt/backend-server/pb/*.pb.go

# IDE
.idea/
.vscode/
.claude/

# OS
.DS_Store
Thumbs.db

# Research/Reports
reports

# Log analysis (local only)
logs-analysis/

# Local-only working artifacts: ops scripts, host-specific config, secrets,
# and every planning/spec/brainstorm document. Only user-facing docs are
# tracked; design notes live here and never reach the repository.
scripts/localonly/

# Planning and design artifacts (GSD, superpowers, agent scratch)
.planning/
docs/superpowers/

# Example signers: build output and installed dependencies. The examples are
# source to read and copy; everything a toolchain generates from them stays out.
examples/**/node_modules/
examples/**/target/
examples/**/__pycache__/
examples/**/.ruff_cache/
examples/**/.venv/
# A compiled oracle, wherever a reader builds one. Note this must not swallow
# examples/relay-signing/oracle/, which is the oracle's SOURCE and is tracked —
# hence the per-language paths rather than a bare `oracle`.
examples/**/oracle-bin
examples/relay-signing/nodejs/oracle
examples/relay-signing/python/oracle
examples/relay-signing/rust/oracle
# `go build ./examples/relay-signing/oracle` from the repo root drops a 5 MB
# binary here. Root-anchored, so it cannot swallow the source dir above.
/oracle
